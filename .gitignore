# Outputs (keep demo, ignore raw plots)
outputs/*.png
outputs/*.jpg
outputs/*.pdf
!outputs/demo/.gitkeep

# Data (optional, keep small samples)
data/*.parquet
data/*.arrow
!data/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Hugging Face cache
~/.cache/huggingface/
