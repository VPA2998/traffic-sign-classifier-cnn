# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/

# Jupyter
.ipynb_checkpoints

# PyTorch
*.pth
*.pt
*.onnx
*.ckpt

# Models (large binaries)
models/*.pth
models/*.pt
